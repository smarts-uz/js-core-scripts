# ─────────────────────────────────────────────────────────────────────────────
# Template for .env — copy to ".env" and fill in real values. Tracked in git.
# The real .env is gitignored and must NEVER be committed.
# Secrets are read at runtime via dotenv (process.env.<NAME>) by the shared
# utils/ integrations (Didox, MySoliq, IjaraSoliq, KapitalBank).
# ─────────────────────────────────────────────────────────────────────────────

# Didox Partner API (utils/Didox.js)
# DIDOX_BASE_URL is non-secret — it lives in config.yml (Didox.BaseURL), not here.
DIDOX_USER_KEY=
DIDOX_PARTNER_AUTHORIZATION=
DIDOX_LOGIN_PASSWORD=
DIDOX_SRENTAL=

# My3 / MySoliq API (utils/MySoliq.js)
MY3_API_SRENTAL=
MY3_SRENTAL=

# Ijara Soliq (utils/IjaraSoliq.js, utils/Didox.js)
IJARA_SRENTAL=

# Kapital Bank (utils/KapitalBank.js)
KAPITAL_SRENTAL=
KAPITAL_ID_SRENTAL=
