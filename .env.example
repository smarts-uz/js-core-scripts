# ─────────────────────────────────────────────────────────────────────────────
# Template for .env — copy to ".env" in the CONSUMER project's root (next to the
# entry script) and fill in real values. The real .env is gitignored; never commit it.
# Read at runtime via dotenv (process.env.<NAME>) through utils/Secrets.js.
# Secrets.get('Section','Owner') maps to <SECTION>_<OWNER> (e.g. Didox/SRental -> DIDOX_SRENTAL).
# ─────────────────────────────────────────────────────────────────────────────

# Didox Partner API (utils/Didox.js)
DIDOX_BASE_URL=https://api-partners.didox.uz
DIDOX_USER_KEY=
DIDOX_PARTNER_AUTHORIZATION=
DIDOX_LOGIN_PASSWORD=
DIDOX_SRENTAL=

# My3 / MySoliq API (utils/MySoliq.js)
MY3_API_SRENTAL=
MY3_SRENTAL=

# Ijara Soliq (utils/IjaraSoliq.js, utils/Didox.js)
IJARA_SRENTAL=

# Kapital Bank (utils/KapitalBank.js)
KAPITAL_SRENTAL=
KAPITAL_ID_SRENTAL=
