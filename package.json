{
    "name": "js_ai_category",
    "version": "1.0.0",
    "description": "Node.js (ESM) CLI tools for processing Office and Markdown documents on Windows.",
    "type": "module",
    "private": true,
    "license": "MIT",
    "author": "Asror Zakirov <asror.zk@gmail.com>",
    "engines": {
        "node": ">=20"
    },
    "scripts": {
        "test": "cross-env NODE_OPTIONS=--experimental-vm-modules jest",
        "test:watch": "cross-env NODE_OPTIONS=--experimental-vm-modules jest --watch",
        "test:coverage": "cross-env NODE_OPTIONS=--experimental-vm-modules jest --coverage",
        "lint": "eslint .",
        "lint:fix": "eslint . --fix",
        "format": "prettier --write .",
        "format:check": "prettier --check .",
        "generate:runners": "node runs/_generate.mjs",
        "generate:readme": "node runs/_gen-readme.mjs",
        "generate:shell": "node runs/_wire-shell.mjs",
        "generate:launch": "node runs/_wire-launch.mjs",
        "prepare": "husky"
    },
    "lint-staged": {
        "!(runs/*/**).{js,mjs}": [
            "eslint --fix",
            "prettier --write"
        ],
        "*.{json,yml,yaml,md}": [
            "prettier --write"
        ]
    },
    "devDependencies": {
        "@eslint/js": "^9.17.0",
        "eslint": "^9.17.0",
        "globals": "^15.14.0",
        "husky": "^9.1.7",
        "lint-staged": "^15.3.0",
        "prettier": "^3.4.2"
    }
}
